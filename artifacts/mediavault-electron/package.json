{
  "name": "@workspace/mediavault-electron",
  "version": "1.0.0",
  "private": true,
  "description": "MediaVault — local-first media manager desktop app",
  "main": "dist/main.js",
  "scripts": {
    "build": "node build.mjs",
    "dist": "node build.mjs --package",
    "dist:win": "node build.mjs --package --win",
    "dist:mac": "node build.mjs --package --mac",
    "dist:linux": "node build.mjs --package --linux"
  },
  "dependencies": {
    "embedded-postgres": "17.10.0-beta.17"
  },
  "devDependencies": {
    "electron": "^36.3.1",
    "electron-builder": "^26.0.12",
    "esbuild": "0.27.3",
    "@types/node": "^25.3.3",
    "typescript": "~5.9.3"
  },
  "build": {
    "extends": null,
    "appId": "com.mediavault.app",
    "productName": "MediaVault",
    "copyright": "Copyright © 2024",
    "directories": {
      "output": "dist-installer",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**",
      "!dist/**/*.map"
    ],
    "extraResources": [
      {
        "from": "../mediavault/dist-electron/",
        "to": "frontend",
        "filter": ["**/*"]
      },
      {
        "from": "../api-server/dist/",
        "to": "server",
        "filter": ["**/*", "!*.map"]
      }
    ],
    "asarUnpack": [
      "node_modules/embedded-postgres/**"
    ],
    "win": {
      "icon": "build-resources/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MediaVault",
      "uninstallDisplayName": "MediaVault"
    },
    "mac": {
      "icon": "build-resources/icon.icns",
      "category": "public.app-category.entertainment",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ]
    },
    "dmg": {
      "title": "MediaVault",
      "contents": [
        { "x": 140, "y": 200 },
        { "x": 380, "y": 200, "type": "link", "path": "/Applications" }
      ]
    },
    "linux": {
      "icon": "build-resources/icon.png",
      "category": "AudioVideo",
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] },
        { "target": "rpm", "arch": ["x64"] }
      ]
    },
    "deb": {
      "depends": ["libsecret-1-0"]
    }
  }
}
